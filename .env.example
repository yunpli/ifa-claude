# ─────────────────────────────────────────────────────────────────────────────
# iFA env template — non-secret defaults only.
# Real keys live in /Users/neoclaw/claude/ifaenv/secrets/.env (NOT in repo).
# ifa.config loads that file first, then this one as fallback.
# ─────────────────────────────────────────────────────────────────────────────

# Where to find the local secrets file (override if you keep it elsewhere)
IFA_SECRETS_FILE=/Users/neoclaw/claude/ifaenv/secrets/.env

# Run mode: test | manual | production
#   test       — outputs to out/test/, may use mocked data, never affects prod tables
#   manual     — post-deploy human trigger, writes to prod DB, output to out/manual/
#   production — cron-triggered, writes to prod DB, output to out/production/
IFA_RUN_MODE=manual

# Output root (where rendered HTML / JSON snapshots land, partitioned by mode)
IFA_OUTPUT_ROOT=/Users/neoclaw/claude/ifaenv/out

# Logs root
IFA_LOG_ROOT=/Users/neoclaw/claude/ifaenv/logs

# Timezone for all report scheduling logic
IFA_TIMEZONE=Asia/Shanghai

# ─── Secrets (templates only — actual values in IFA_SECRETS_FILE) ────────────
# TUSHARE_TOKEN=
# LLM_PRIMARY_BASE_URL=https://jmrai.net/v1
# LLM_PRIMARY_API_KEY=
# LLM_PRIMARY_MODEL=gpt-5.4
# LLM_FALLBACK_BASE_URL=http://177.54.159.23:8081/v1
# LLM_FALLBACK_API_KEY=
# LLM_FALLBACK_MODEL=gpt-5.5
# PG_HOST=127.0.0.1
# PG_PORT=55432
# PG_USER=ifa
# PG_PASSWORD=
# PG_DB_PRODUCTION=ifavr
# PG_DB_TEST=ifavr_test
